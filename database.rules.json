{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "username": {
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        },
        "isGuest": {
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        },
        "stats": {
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        },
        "friendRequests": {
          "$fromUid": {
            ".read": "$uid === auth.uid",
            ".write": "auth != null && (auth.uid === $fromUid || auth.uid === $uid)"
          }
        },
        "friends": {
          "$friendUid": {
            ".read": "$uid === auth.uid",
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)"
          }
        }
      }
    },
    "usernames": {
      ".read": "auth != null",
      "$username": {
        ".write": "auth != null && ((!newData.exists() && data.val() === auth.uid) || (newData.exists() && newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)))"
      }
    },
    "games": {
      ".indexOn": ["players/joiner", "players/host"],
      "$gameId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('players').child('host').val() === auth.uid || data.child('players').child('joiner').val() === auth.uid || (!data.child('players').child('joiner').exists() && newData.child('players').child('host').val() === data.child('players').child('host').val() && newData.child('players').child('joiner').val() === auth.uid))"
      }
    },
    "matchmaking": {
      ".read": "auth != null",
      ".indexOn": ["joinedAt"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "matchmakingPairs": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "matchmakingRanked": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true",
      ".indexOn": ["joinedAt"],
      "$uid": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true",
        ".write": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true"
      }
    },
    "matchmakingRankedPairs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true"
    },
    "leaderboards": {
      ".read": "auth != null",
      ".indexOn": ["elo", "wins", "losses", "winRate"],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && root.child('users').child(auth.uid).child('isGuest').val() !== true"
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true",
        ".write": "auth != null && root.child('users').child(auth.uid).child('isGuest').val() !== true",
        ".indexOn": ["sentAt"]
      }
    },
    "friends": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    }
  }
}
